DATABASE_URL=postgresql+asyncpg://kprueck:kprueck@localhost:5433/kprueck
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional overrides
# API_V1_PREFIX=/api
# PROJECT_NAME=KP Rück API
# HOST=0.0.0.0
# PORT=8000
# RELOAD=true

# Authentication (all with AUTH_ prefix)
# AUTH_BYPASS_DEV=true  # DEVELOPMENT ONLY: Bypass authentication (returns mock editor user)
# AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15  # JWT access token lifetime (default: 15 minutes)
# AUTH_SECRET_KEY=your-secret-key-here  # Generate with: openssl rand -hex 32

# Microsoft Entra ID Login (optional - omit to disable)
# MICROSOFT_CLIENT_ID=<from Azure App Registration>
# MICROSOFT_TENANT_ID=<from Azure App Registration>
# MICROSOFT_CLIENT_SECRET=<client secret VALUE, not the Secret ID!>
# MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/callback

# Divera Polling (fallback for webhooks)
# Polling only runs when users are connected via WebSocket - avoids API abuse
# DIVERA_ACCESS_KEY=your-divera-api-key  # Get from Divera: Administration > Settings > Interfaces > API
# DIVERA_API_URL=https://app.divera247.com/api/v2  # Default Divera API URL
# DIVERA_POLL_INTERVAL_SECONDS=30  # How often to poll when users are connected (default: 30)
# DIVERA_POLL_MAX_ALARMS=50  # Max alarms to fetch per poll (default: 50)
